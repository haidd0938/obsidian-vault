# 环境变量 — 填入你的 API 密钥
# 复制一份到 ~/.hermes/.env

# ===== 保险一：OpenRouter（主力推荐） =====
# 注册: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ===== 保险二：DeepSeek 官方 =====
# 注册: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ===== 保险三：NVIDIA NIM（免费备胎） =====
# 注册: https://build.nvidia.com/
NVIDIA_API_KEY=

# ===== 其他服务（按需） =====
# 如果要用 Telegram 通知
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 如果要用微博/其他
# WEIBO_TOKEN=
